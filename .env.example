# blackheart-ingest environment template — copy to .env and fill in.

# ── Postgres (shared with trading JVM via Tailscale in prod; local in dev) ──
# Use blackheart_trading role (writes to *_raw + ml_source_health).
INGEST_DB_HOST=localhost
INGEST_DB_PORT=5432
INGEST_DB_NAME=trading_db
INGEST_DB_USER=blackheart_trading
INGEST_DB_PASSWORD=trading_dev_pass

# ── HTTP server ──────────────────────────────────────────────────────────────
# Loopback only — Java handlers reach it via 127.0.0.1 (same host as the
# trading JVM in dev) or via Tailscale in prod when handlers run on VPS but
# ingest runs on home.
INGEST_SERVER_HOST=127.0.0.1
INGEST_SERVER_PORT=8089

# ── Source-specific credentials ──────────────────────────────────────────────

# FRED — free API key from https://fredaccount.stlouisfed.org/apikeys
INGEST_FRED_API_KEY=

# Binance — public endpoints only (funding, OI, L/S), no auth required.
# (No key needed for live_ingest; trading JVM owns the authenticated keys.)

# ── Behavior flags ──────────────────────────────────────────────────────────
# Max age (hours) between event_time and ingestion_time before a row is
# rejected by PIT guards. Override per source via the registry config.
INGEST_DEFAULT_MAX_BACKFILL_LAG_HOURS=72

# Log level: DEBUG | INFO | WARNING | ERROR
INGEST_LOG_LEVEL=INFO
